@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix mobility: <http://example.org/mobility/> .

<dataset/network-speed>
 a dcat:Dataset ;
 dct:title "Traffic Network Speed Dataset" ;
 dct:description "Current speeds on road links in Thessaloniki" ;
 dct:publisher "CERTH-HIT" ;
 mobility:transportMode "road" ;
 mobility:mobilityTheme "traffic conditions" ;
 mobility:networkCoverage "urban road network" ;
 dcat:distribution <dataset/network-speed/dist1> .

<dataset/network-speed/dist1>
 a dcat:Distribution ;
 dcat:accessURL <https://opendata.imet.gr/dataset/network-speed> .